---
import trip from "../data/trip.json";
import "leaflet/dist/leaflet.css";

const pointCount = trip.map.points.length;
const mapPayload = JSON.stringify({
  points: trip.map.points,
  routes: trip.map.routes,
  typeLabels: trip.map.typeLabels,
  routeLabels: trip.map.routeLabels
});
---

<section class="map-shell" aria-labelledby="map-title">
  <div class="map-copy">
    <p class="eyebrow">Карта маршрута</p>
    <h2 id="map-title">{pointCount} точек с понятным порядком</h2>
    <p>
      Цифры показывают порядок маршрута. Сплошная линия - основные базы, пунктир - островной день и optional-направления.
      В карточках справа у каждой точки указано, к какой дате или блоку поездки она относится.
    </p>
    <div class="legend" aria-label="Легенда карты">
      <span><i class="dot airport"></i>Аэропорт</span>
      <span><i class="dot base"></i>База</span>
      <span><i class="dot day"></i>Выезд</span>
      <span><i class="dot ferry"></i>Паром</span>
      <span><i class="dot optional"></i>Optional</span>
    </div>
  </div>
  <div class="route-explainer" aria-label="Что означают линии на карте">
    <article>
      <span class="line-sample main"></span>
      <strong>{trip.map.routeLabels.main}</strong>
      <p>Только крупные переезды между районами, где живём.</p>
    </article>
    <article>
      <span class="line-sample island"></span>
      <strong>{trip.map.routeLabels.island}</strong>
      <p>Optional-день из финальной базы через Sanur Port на Nusa Lembongan / Ceningan и обратно.</p>
    </article>
    <article>
      <span class="line-sample optional"></span>
      <strong>{trip.map.routeLabels.optional}</strong>
      <p>Запасные или условные направления, которые не являются обязательным скелетом маршрута.</p>
    </article>
    <article>
      <span class="point-sample day"></span>
      <strong>Синие точки без линий</strong>
      <p>Локальные места внутри базы: их смотрим из ближайшего района, но не соединяем все линии на карте.</p>
    </article>
  </div>
  <div class="map-layout">
    <div id="route-map" class="route-map" aria-label="Интерактивная карта Бали"></div>
    <aside class="route-panel" aria-label="Точки маршрута">
      <div class="map-filters" aria-label="Фильтр точек карты">
        <button type="button" class="active" data-filter="all">Все</button>
        <button type="button" data-filter="base">Базы</button>
        <button type="button" data-filter="day">Выезды</button>
        <button type="button" data-filter="island">Острова</button>
        <button type="button" data-filter="optional">Optional</button>
      </div>
      <nav id="route-list" class="route-list" aria-label="Точки маршрута"></nav>
      <p id="route-empty" class="route-empty" hidden>Для этого фильтра нет точек.</p>
    </aside>
  </div>
  <script id="route-map-data" type="application/json" set:html={mapPayload} is:inline></script>
</section>

<script>
  import L from "leaflet";

  type RoutePoint = {
    order: number;
    title: string;
    type: "airport" | "base" | "day" | "ferry" | "optional";
    dateLabel: string;
    role: string;
    lat: number;
    lng: number;
    description: string;
  };

  type MapPayload = {
    points: RoutePoint[];
    routes: {
      main: number[];
      island: number[];
      optional: number[][];
    };
    typeLabels: Record<RoutePoint["type"], string>;
    routeLabels: {
      main: string;
      island: string;
      optional: string;
    };
  };

  const payloadEl = document.getElementById("route-map-data");
  const mapEl = document.getElementById("route-map");
  const listEl = document.getElementById("route-list");
  const emptyEl = document.getElementById("route-empty");
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".map-filters button"));

  if (payloadEl && mapEl && listEl && emptyEl) {
    const routeListEl = listEl;
    const routeEmptyEl = emptyEl;
    const data = JSON.parse(payloadEl.textContent || "{}") as MapPayload;
    const pointsByOrder = new Map(data.points.map((point) => [point.order, point]));
    const islandOrders = new Set(data.routes.island);

    const map = L.map(mapEl, {
      zoomControl: true,
      scrollWheelZoom: true
    });

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(map);

    const markers = new Map<number, L.Marker>();
    const bounds = L.latLngBounds(data.points.map((point) => [point.lat, point.lng]));

    function iconFor(point: RoutePoint) {
      return L.divIcon({
        className: "",
        html: `<span class="number-marker ${point.type}">${point.order}</span>`,
        iconSize: [34, 34],
        iconAnchor: [17, 17],
        popupAnchor: [0, -18]
      });
    }

    function popupFor(point: RoutePoint) {
      const label = data.typeLabels[point.type];
      return `
        <article class="map-popup">
          <h3>${String(point.order).padStart(2, "0")}. ${point.title}</h3>
          <p class="popup-date">${point.dateLabel}</p>
          <p class="popup-meta">${label} · ${point.role}</p>
          <p>${point.description}</p>
        </article>
      `;
    }

    data.points.forEach((point) => {
      const marker = L.marker([point.lat, point.lng], {
        icon: iconFor(point),
        title: `${String(point.order).padStart(2, "0")}. ${point.title}`
      }).addTo(map);
      marker.bindPopup(popupFor(point));
      markers.set(point.order, marker);
    });

    function shouldShowPoint(point: RoutePoint, filter: string) {
      if (filter === "all") {
        return true;
      }

      if (filter === "base") {
        return point.type === "base" || point.type === "airport";
      }

      if (filter === "island") {
        return islandOrders.has(point.order) || point.title.includes("Nusa Penida");
      }

      return point.type === filter;
    }

    function routeLine(orders: number[]) {
      return orders
        .map((order) => pointsByOrder.get(order))
        .filter((point): point is RoutePoint => Boolean(point))
        .map((point) => [point.lat, point.lng] as [number, number]);
    }

    L.polyline(routeLine(data.routes.main), {
      color: "#0f766e",
      weight: 4,
      opacity: 0.86
    }).addTo(map);

    L.polyline(routeLine(data.routes.island), {
      color: "#7c3aed",
      weight: 3,
      opacity: 0.78,
      dashArray: "8 8"
    }).addTo(map);

    data.routes.optional.forEach((route) => {
      L.polyline(routeLine(route), {
        color: "#a16207",
        weight: 2,
        opacity: 0.68,
        dashArray: "4 8"
      }).addTo(map);
    });

    function fitRouteBounds() {
      map.invalidateSize();
      map.fitBounds(bounds.pad(0.16));
    }

    fitRouteBounds();
    window.addEventListener("load", () => window.setTimeout(fitRouteBounds, 250));
    window.addEventListener("resize", () => window.setTimeout(fitRouteBounds, 120));

    function createPointButton(point: RoutePoint) {
      const button = document.createElement("button");
      button.className = `route-point ${point.type === "base" || point.type === "airport" ? "is-anchor" : ""}`;
      button.type = "button";
      button.innerHTML = `
        <span class="point-num ${point.type}">${point.order}</span>
        <span>
          <strong>${String(point.order).padStart(2, "0")}. ${point.title}</strong>
          <small class="route-date">${point.dateLabel}</small>
          <small>${data.typeLabels[point.type]} · ${point.role}</small>
        </span>
      `;
      button.addEventListener("click", () => {
        const marker = markers.get(point.order);
        map.setView([point.lat, point.lng], Math.max(map.getZoom(), 12), { animate: true });
        marker?.openPopup();
      });
      return button;
    }

    function renderPointList(filter = "all") {
      routeListEl.innerHTML = "";
      const visiblePoints = data.points.filter((point) => shouldShowPoint(point, filter));

      visiblePoints.forEach((point) => {
        routeListEl.appendChild(createPointButton(point));
      });

      routeEmptyEl.hidden = visiblePoints.length > 0;
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        filterButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        renderPointList(button.dataset.filter || "all");
      });
    });

    renderPointList();
  }
</script>
