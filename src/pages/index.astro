---
import RouteMap from "../components/RouteMap.astro";
import trip from "../data/trip.json";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const totalNights = trip.bases.reduce((sum, base) => sum + base.nights, 0);
const accommodationMoves = Math.max(trip.bases.length - 1, 0);
const placesByBase = trip.bases.map((base) => ({
  base,
  places: trip.places.filter((place) => place.base === base.name)
}));
const dayDetailsByDate = new Map(trip.dayDetails.map((detail) => [detail.date, detail]));
type Place = (typeof trip.places)[number];
type Day = (typeof trip.days)[number];
type DayDetail = (typeof trip.dayDetails)[number];
const placeAliases: Record<string, string[]> = {
  "Batu Bolong / Echo Beach": ["Batu Bolong", "Echo Beach"],
  "Seminyak / Petitenget": ["Seminyak", "Petitenget"],
  "Tegallalang Rice Terraces": ["Tegallalang", "рисовые террасы"],
  "Mount Batur / Kintamani": ["Mount Batur", "Batur", "Kintamani", "вулкан"],
  "Uluwatu Temple + Kecak": ["Uluwatu Temple", "Kecak", "храм Uluwatu", "Kecak dance"],
  "Nusa Lembongan / Ceningan": ["Nusa Lembongan", "Lembongan", "Ceningan"],
  "Snorkeling - снорклинг": ["snorkeling", "снорклинг"],
  "Sanur Beach Promenade": ["Sanur Beach", "promenade"],
  "Nusa Dua / Geger Beach": ["Nusa Dua", "Geger Beach"]
};
const normalize = (value: string) => value.toLowerCase().replaceAll("’", "'").replace(/[^a-zа-яё0-9]+/giu, " ").trim();
const includesTerm = (text: string, term: string) => {
  const normalizedTerm = normalize(term);
  return normalizedTerm.length > 2 && normalize(text).includes(normalizedTerm);
};
const getPlaceTerms = (place: Place) => [
  place.name,
  ...(placeAliases[place.name] ?? []),
  ...place.name.split(/\s*(?:\/|\+)\s*/u)
];
const getDayPlaces = (day: Day, details?: DayDetail) => {
  const detailText = details
    ? [
        ...details.timing,
        details.focus,
        details.fallback,
        details.foodRest,
        ...details.warnings
      ].join(" ")
    : "";
  const dayText = [day.title, day.plan, day.notes, detailText].join(" ");

  return trip.places.filter((place) => getPlaceTerms(place).some((term) => includesTerm(dayText, term)));
};
const navItems = [
  ["overview", "Обзор"],
  ["map", "Карта"],
  ["flights", "Перелёты"],
  ["bases", "Базы"],
  ["days", "Дни"],
  ["places", "Места"],
  ["transfers", "Логистика"],
  ["budget", "Финансы"],
  ["decisions", "Решения"]
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Семейный маршрут поездки на Бали 2026: карта, базы, дни и переезды." />
    <title>{trip.title} - маршрут</title>
  </head>
  <body>
    <header class="hero">
      <nav class="topbar" aria-label="Основная навигация">
        <a href={baseUrl} class="brand">Bali 2026</a>
        <div>
          <a href="#map">Карта</a>
          <a href="#bases">Базы</a>
          <a href="#days">Дни</a>
          <a href="#transfers">Переезды</a>
        </div>
      </nav>
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Семейная поездка</p>
          <h1>{trip.title}</h1>
          <p class="lead">{trip.subtitle}</p>
          <p>{trip.summary.coreIdea}</p>
        </div>
        <aside class="trip-facts" aria-label="Краткая сводка">
          <div>
            <span>Свадьба</span>
            <strong>{trip.summary.weddingDate}</strong>
          </div>
          <div>
            <span>Бали</span>
            <strong>{totalNights} ночей</strong>
          </div>
          <div>
            <span>Жильё</span>
            <strong>{trip.bases.length} точек</strong>
          </div>
          <div>
            <span>Смены жилья</span>
            <strong>{accommodationMoves} переезда</strong>
          </div>
        </aside>
      </div>
    </header>

    <nav class="section-tabs" aria-label="Разделы маршрута">
      {navItems.map(([href, label]) => <a href={`#${href}`}>{label}</a>)}
    </nav>

    <main>
      <section id="overview" class="section intro">
        <div>
          <p class="eyebrow">Главная логика</p>
          <h2>Живём базами, а не ездим через весь остров каждый день</h2>
        </div>
        <p>
          Маршрут собран вокруг точек проживания: каждый переезд в новый блок жилья считается новой точкой, даже если район уже знакомый.
          Сейчас это 5 точек проживания и 4 основных переезда между ними. Отдельно идут прилёт из DPS, финальный выезд в DPS и optional-выезд через Sanur Port.
          Свадебный блок в Umalas остаётся отдельной точкой проживания и фиксированным якорем.
        </p>
      </section>

      <div id="map">
        <RouteMap />
      </div>

      <section id="flights" class="section">
        <div class="section-head">
          <p class="eyebrow">Перелёты</p>
          <h2>Ключевые времена дороги</h2>
          <p>В публичной версии нет номеров бронирований, билетов и документов. Здесь только расписание и практические буферы.</p>
        </div>
        <div class="flight-grid">
          {trip.flights.map((flight) => (
            <article class="flight-card">
              <div class="card-topline">
                <span>✈</span>
                <small>{flight.date}</small>
              </div>
              <h3>{flight.direction}</h3>
              <p class="role">{flight.airline}</p>
              <div class="segments">
                {flight.segments.map((segment) => (
                  <div class="segment">
                    <strong>{segment.from} -> {segment.to}</strong>
                    <span>{segment.departure} -> {segment.arrival}</span>
                    <small>{segment.note}</small>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
        <div class="notice">
          <strong>Выезд из дома:</strong> на рейс 18 Oct 22:20 из SVO C текущий ориентир - выехать из Солнцево около 17:00 и быть в аэропорту к 18:45-19:00.
        </div>
      </section>

      <section id="bases" class="section">
        <div class="section-head">
          <p class="eyebrow">Базы проживания</p>
          <h2>5 точек проживания и 4 переезда между ними</h2>
        </div>
        <div class="base-grid">
          {trip.bases.map((base) => (
            <article class="base-card">
              <div class="card-topline">
                <span>{String(base.order).padStart(2, "0")}</span>
                <small>{base.dates} · {base.nights} ночи</small>
              </div>
              <h3>{base.name}</h3>
              <p class="role">{base.role}</p>
              <p>{base.why}</p>
              <div class="chips">
                {base.nearby.map((item) => {
                  const place = trip.places.find((entry) => entry.name === item || item.includes(entry.name) || entry.name.includes(item));
                  return <span title={place?.description}>{item}</span>;
                })}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="days" class="section">
        <div class="section-head">
          <p class="eyebrow">План по дням</p>
          <h2>Скелет маршрута от вылета до возвращения</h2>
        </div>
        <div class="timeline">
          {trip.days.map((day) => {
            const details = dayDetailsByDate.get(day.date);
            const dayPlaces = getDayPlaces(day, details);
            return (
              <article class="day-card">
                <div class="date-box">
                  <strong>{day.date}</strong>
                  <span>{day.weekday}</span>
                </div>
                <div>
                  <p class="day-base">{day.base}</p>
                  <h3>{day.title}</h3>
                  <p>{day.plan}</p>
                  <p class="note">{day.notes}</p>
                  {dayPlaces.length > 0 && (
                    <div class="day-places" aria-label="Места этого дня">
                      <h4>Места дня</h4>
                      <div class="day-place-grid">
                        {dayPlaces.map((place) => (
                          <article class="day-place">
                            <div>
                              <strong>{place.name}</strong>
                              <small>{place.duration}</small>
                            </div>
                            <p>{place.description}</p>
                            <p class="note">{place.familyNote}</p>
                          </article>
                        ))}
                      </div>
                    </div>
                  )}
                  {details && (
                    <details class="day-details">
                      <summary>Показать детали дня</summary>
                      <div class="detail-grid">
                        <section>
                          <h4>Тайминг</h4>
                          <ul>
                            {details.timing.map((item) => <li>{item}</li>)}
                          </ul>
                        </section>
                        <section>
                          <h4>Смысл дня</h4>
                          <p>{details.focus}</p>
                        </section>
                        <section>
                          <h4>Fallback</h4>
                          <p>{details.fallback}</p>
                        </section>
                        <section>
                          <h4>Еда / отдых</h4>
                          <p>{details.foodRest}</p>
                        </section>
                        <section>
                          <h4>Важно</h4>
                          <ul>
                            {details.warnings.map((item) => <li>{item}</li>)}
                          </ul>
                        </section>
                      </div>
                    </details>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section id="places" class="section">
        <div class="section-head">
          <p class="eyebrow">Справочник мест</p>
          <h2>Что означают все названия в маршруте</h2>
          <p>Здесь каждая точка расшифрована простым языком: что это, зачем туда ехать, сколько занимает и что важно для семьи.</p>
        </div>
        <div class="places-groups">
          {placesByBase.map(({ base, places }) => (
            <section class="place-group">
              <div class="place-group-head">
                <span>{String(base.order).padStart(2, "0")}</span>
                <div>
                  <h3>{base.name}</h3>
                  <p>{base.role}</p>
                </div>
              </div>
              <div class="place-list">
                {places.map((place) => (
                  <article class="place-card">
                    <div class="place-title">
                      <h4>{place.name}</h4>
                      <small>{place.duration}</small>
                    </div>
                    <div class="badges">
                      {place.badges.map((badge) => <span class={`badge ${badge.replaceAll(" ", "-")}`}>{badge}</span>)}
                    </div>
                    <p>{place.description}</p>
                    <p class="note">{place.familyNote}</p>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section id="transfers" class="section">
        <div class="section-head">
          <p class="eyebrow">Логистика</p>
          <h2>Главные переезды и окна выезда</h2>
        </div>
        <div class="transfer-list">
          {trip.transfers.map((transfer) => (
            <article class="transfer-card">
              <h3>{transfer.from} -> {transfer.to}</h3>
              <dl>
                <div>
                  <dt>Расстояние</dt>
                  <dd>{transfer.distance}</dd>
                </div>
                <div>
                  <dt>Время</dt>
                  <dd>{transfer.time}</dd>
                </div>
                <div>
                  <dt>Транспорт</dt>
                  <dd>{transfer.transport}</dd>
                </div>
                <div>
                  <dt>Когда ехать</dt>
                  <dd>{transfer.window}</dd>
                </div>
              </dl>
              <p>{transfer.note}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="budget" class="section">
        <div class="section-head">
          <p class="eyebrow">Финансы</p>
          <h2>Пока лёгкий бюджетный контур</h2>
          <p>Excel в эту итерацию не импортируем. Здесь только категории, чтобы не потерять будущую структуру бюджета.</p>
        </div>
        <div class="budget-grid">
          {trip.budgetSummary.map((item) => (
            <article class="budget-card">
              <div class="card-topline">
                <span>₽</span>
                <small>{item.status}</small>
              </div>
              <h3>{item.category}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="decisions" class="section">
        <div class="section-head">
          <p class="eyebrow">Решения и TBD</p>
          <h2>Что уже зафиксировано и что ещё надо решить</h2>
        </div>
        <div class="decision-grid">
          {trip.decisions.map((decision) => (
            <article class={`decision-card ${decision.status}`}>
              <span>{decision.status === "done" ? "решено" : "TBD"}</span>
              <h3>{decision.title}</h3>
              <p>{decision.details}</p>
            </article>
          ))}
        </div>
        <div class="resources">
          <h3>Ресурсы</h3>
          <div class="resource-list">
            {trip.resources.map((resource) => (
              <article>
                <strong>{resource.title}</strong>
                <span>{resource.type} · {resource.status}</span>
                {resource.url ? <a href={resource.url}>{resource.url}</a> : <em>Ссылка будет добавлена позже</em>}
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section safety">
        <div>
          <p class="eyebrow">Правило проекта</p>
          <h2>Текст и карта завязаны на один источник</h2>
        </div>
        <p>
          Все публичные блоки сайта строятся из <code>src/data/trip.json</code>. Если меняется порядок баз, точка карты,
          день или переезд, обновляется этот файл, а сайт пересобирается. Приватные данные в публичный repo не добавляются.
        </p>
      </section>
    </main>
  </body>
</html>
